# Ignore old output directories (deprecated in favor of experiments/)
runs/*
logs/*
weights/*
results/*

# Ignore new experiments directory
experiments/*

# Ignore any folder called runs anywhere in the tree
**/runs/

# Ignore all __pycache__ directories and .pyc files
**/__pycache__/
*.pyc

# Ignore all .cache files and build artifacts
*.cache
*.pt
paper.md

# Ignore downloaded YOLO pretrained weights in root
/yolo*.pt

# Ignore environment and package directories
/dec_3_flower_env
/FedYOLO.egg-info
/fedyolo.egg-info
*.egg-info/
.rustup/
.local/

# Ignore config directories and flwr app data
.config/
.flwr/

# Ignore test and coverage artifacts
.tox/
.coverage
htmlcov/
.pytest_cache/

# Ignore build artifacts
dist/
build/
